# Copy this file to .env.local and fill it in.

# Read-only bearer token from your X developer console app (powers `npm run refresh`).
X_BEARER_TOKEN=

# context.dev API key (powers `npm run enrich` and `npm run avatars`).
CONTEXT_DEV_API_KEY=

# OAuth 2.0 client from your X app's "User authentication settings"
# (powers Sign in with X). The redirect URI must match the one configured
# in the X developer portal exactly.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Shared Postgres for sessions and sign-ups (required in production, where
# the filesystem is ephemeral; local dev falls back to SQLite without it).
DATABASE_URL=

# GrayPass passive monitoring (time-boxed research data collection).
# All four must be set or the monitor never loads. The publishable key is
# rendered into the page; the secret key stays server-side and is only used
# by /api/graypass/token to mint short-lived browser tokens.
GRAYPASS_API_BASE=https://api.graypass.org
GRAYPASS_PUBLISHABLE_KEY=
GRAYPASS_SECRET_KEY=
# Hard end of the collection window (ISO 8601). Set to 14 days after launch.
GRAYPASS_COLLECT_UNTIL=2026-08-06T00:00:00Z
